<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.github.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".RegisterActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvRegisterTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textColor="#0F172A"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tvRegisterSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start managing your personal finances today"
                android:textColor="#64748B"
                android:textSize="15sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="40dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="#334155"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etRegisterName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:backgroundTint="#E2E8F0"
                        android:hint="Sidd Nayak"
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F172A"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="16dp"
                        android:textSize="16sp"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address"
                        android:textColor="#334155"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etRegisterEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:backgroundTint="#E2E8F0"
                        android:hint="name@example.com"
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F172A"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="16dp"
                        android:textSize="16sp"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textColor="#334155"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etRegisterPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:backgroundTint="#E2E8F0"
                        android:hint="Create a strong password"
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F172A"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:textSize="16sp"
                        android:layout_marginBottom="32dp" />

                    <Button
                        android:id="@+id/btnRegister"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Sign Up"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="#10B981"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="14dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? Sign In"
                android:textColor="#475569"
                android:textSize="15sp"
                android:layout_marginTop="32dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>