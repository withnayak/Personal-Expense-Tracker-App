<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage Categories"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnGoToBudget"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/btnGoToBudget"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Set Budget"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F172A"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:paddingHorizontal="16dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textStyle="bold" />

    </RelativeLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_below="@id/layoutHeader"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerDivider"
        android:layout_above="@id/fabAddCategory"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:clipToPadding="false"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:backgroundTint="#00B4D8"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="#FFFFFF" />

</RelativeLayout>